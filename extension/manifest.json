{
  "manifest_version": 3,
  "name": "FocusGuard",
  "version": "2.0.0",
  "description": "Your Behavioral Productivity Operating System — smart tracking, focus mode, and task-based site blocking.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "webNavigation",
    "idle",
    "declarativeNetRequest",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/categories.js", "utils/storage.js", "content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-focus": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Toggle Focus Mode"
    },
    "block-current": {
      "suggested_key": { "default": "Alt+Shift+B" },
      "description": "Block Current Site"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "dynamic_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked/blocked.html",
        "blocked/blocked.css",
        "blocked/blocked.js",
        "onboarding/onboarding.html",
        "onboarding/onboarding.css",
        "onboarding/onboarding.js",
        "assets/styles-common.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
